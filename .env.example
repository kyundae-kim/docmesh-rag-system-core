# Ollama embedding configuration
OLLAMA_EMBED__BASE_URL=http://ollama:11434
OLLAMA_EMBED__MODEL=bge-m3
OLLAMA_EMBED__TIMEOUT=30

# Ollama cloud generation configuration
OLLAMA_GENERATE__BASE_URL=https://ollama.com
OLLAMA_GENERATE__API_KEY=''
OLLAMA_GENERATE__MODEL=gemma3:4b
OLLAMA_GENERATE__TIMEOUT=30

# Milvus Lite vector store configuration
MILVUS__URI=./data/metadata.milvus.db
MILVUS__COLLECTION_NAME=rag_chunks
MILVUS__TIMEOUT=30
